rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to validate text length
    function isValidText(text) {
      return text is string && 
             text.size() > 0 && 
             text.size() <= 1000;
    }
    
    // Helper function to validate geo-cell format
    // Accepts both GPS cells (e.g. "2657_15519") and room cells (e.g. "room_123456")
    function isValidGeoCell(geoCell) {
      return geoCell is string && 
             (geoCell.matches('^-?[0-9]+_-?[0-9]+$') || geoCell.matches('^room_[0-9]{4,10}$'));
    }
    
    // Snippets collection rules
    match /snippets/{snippetId} {
      // Anyone can read active snippets
      allow read: if true;
      
      // Strict validation on creation - must be signed in and own the doc
      allow create: if request.auth != null &&
                       request.auth.uid == request.resource.data.owner_id &&
                       isValidText(request.resource.data.text) && 
                       isValidGeoCell(request.resource.data.geo_cell) &&
                       request.resource.data.expires_at is timestamp &&
                       request.resource.data.expires_at > request.time &&
                       request.resource.data.expires_at <= request.time + duration.value(86400, 's');
                       
      // Only the original owner can update (text only) or delete their own snippet
      allow update: if request.auth != null &&
                       request.auth.uid == resource.data.owner_id &&
                       request.resource.data.owner_id == resource.data.owner_id &&
                       request.resource.data.geo_cell == resource.data.geo_cell &&
                       request.resource.data.expires_at == resource.data.expires_at &&
                       isValidText(request.resource.data.text);
                       
      allow delete: if request.auth != null &&
                       request.auth.uid == resource.data.owner_id;
    }
    
    // Rooms collection rules
    match /rooms/{roomId} {
      // Prevent mass scraping (enumeration) of all private rooms
      allow list: if false;
      // Allow exact ID lookups
      allow get: if true;
      
      // Allow creation and lifecycle management
      allow create, update, delete: if true;
    }
  }
}
